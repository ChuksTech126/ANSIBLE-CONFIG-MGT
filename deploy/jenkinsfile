stage('Ansible Preparation') {
    steps {
        sh "echo ${env.WORKSPACE}"
        sh """sed -i '3 a roles_path=${env.WORKSPACE}/roles:${env.WORKSPACE}/static-assignments/roles' ${env.WORKSPACE}/deploy/ansible.cfg"""
    }
}

stage('Ansible Connection Test') {
    steps {
        sshagent(['private']) {
            sh "ansible all -m ping -i ${env.WORKSPACE}/inventory/dev"
        }
    }
}

stage('Run Ansible Playbook') {
    steps {
        ansiblePlaybook(
            become: true,
            credentialsId: 'private',
            disableHostKeyChecking: true,
            installation: 'ansible',
            inventory: "${env.WORKSPACE}/inventory/dev",
            playbook: "${env.WORKSPACE}/Playbooks/site.yml"
        )
    }
}
